# =============================================================================
# SAT-MSS — Environment Variables Template
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file containing real secret values.
# =============================================================================

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://satmss:satmss_local_password@localhost:5432/satmss
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# OBJECT STORAGE (MinIO — local dev; swap with S3/GCS in production)
# =============================================================================
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=satmss_minio_access
MINIO_SECRET_KEY=satmss_minio_secret_key_change_in_prod
MINIO_BUCKET_IMAGERY=satmss-imagery
MINIO_BUCKET_EXPORTS=satmss-exports
MINIO_BUCKET_REPORTS=satmss-reports
MINIO_USE_SSL=false

# =============================================================================
# AUTHENTICATION
# =============================================================================
# JWT_SECRET: minimum 64 characters, cryptographically random
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_64_CHARACTER_RANDOM_STRING_BEFORE_ANY_DEPLOYMENT
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_SECURE_64_CHARACTER_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=30d
SESSION_SECRET=CHANGE_THIS_SESSION_SECRET_TO_A_SECURE_RANDOM_VALUE

# =============================================================================
# GEOSPATIAL ENGINE (GSE)
# =============================================================================
GSE_BASE_URL=http://localhost:8001
# GSE_INTERNAL_SECRET: shared secret for API → GSE internal calls
GSE_INTERNAL_SECRET=CHANGE_THIS_INTERNAL_SECRET_TO_A_SECURE_VALUE

# =============================================================================
# EXTERNAL DATA SOURCES
# =============================================================================
# Copernicus Open Access Hub — register at: https://scihub.copernicus.eu/
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=
COPERNICUS_API_URL=https://scihub.copernicus.eu/dhus

# =============================================================================
# EMAIL (SMTP)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@satmss.gov.in

# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV=development
API_PORT=3001
API_BASE_URL=http://localhost:3001

# Cesium Ion token — get from: https://ion.cesium.com/tokens
NEXT_PUBLIC_CESIUM_ION_TOKEN=

NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# =============================================================================
# GSE (Python FastAPI)
# =============================================================================
GSE_PORT=8001
GSE_WORKERS=2
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Detection algorithm: 'classical' (V1) | 'ml' (V2 future)
DETECTION_STRATEGY=classical

# Minimum NDVI delta to flag a pixel as changed (STANDARD sensitivity)
NDVI_CHANGE_THRESHOLD_STANDARD=0.25
# High sensitivity threshold
NDVI_CHANGE_THRESHOLD_HIGH=0.15
# Minimum zone area to report (hectares)
MIN_ZONE_AREA_HA=1.0
# Maximum cloud cover % for a scene to be eligible for analysis
MAX_CLOUD_COVER_PCT=30

# =============================================================================
# ALERT CONFIGURATION
# =============================================================================
# Minimum severity score to generate an alert (1–100)
ALERT_SEVERITY_THRESHOLD=40
# Minimum severity score to send email notification
EMAIL_NOTIFICATION_THRESHOLD=70

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
